# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
/android/.kotlin/

# Environment variables
.env

# Local dart-define values for `flutter run`. Mirrors what the GitHub
# Actions web deploy injects via repo secrets. Never commit — holds
# real OpenAI / Deepgram / Supabase keys.
dart_defines.json

# Supabase CLI scratch state — project ref, version cache, etc.
# Regenerated on every `supabase link`; nothing here is meaningful
# to source control.
supabase/.temp/

# Claude Code local state — local-only settings + scratch state.
# Project-scoped agents (`.claude/agents/`) ARE tracked so the
# audit definitions persist for the team / future sessions.
.claude/*
!.claude/agents/
